# OpenWeatherMap API key (free tier: https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_api_key_here

# Roboflow API key (https://roboflow.com)
ROBOFLOW_API_KEY=your_api_key_here

# City for weather data
WEATHER_CITY=Tumkur,IN

# Email (SMTP) Alerts — defaults are for Gmail. Use a Gmail App Password,
# not your account password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_APP_PASSWORD=your_app_password

# OpenRouteService (free: https://openrouteservice.org/dev/#/signup)
ORS_API_KEY=your_ors_api_key

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=path/to/firebase-adminsdk-key.json
FIREBASE_PROJECT_ID=your-project-id

# Dashboard auth (set to enable the password gate)
DASHBOARD_PASSWORD=

# SQLite database path (defaults to data/traffic.db)
DATABASE_PATH=data/traffic.db

# Logging
LOG_LEVEL=INFO
